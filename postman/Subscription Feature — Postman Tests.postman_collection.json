        {
          "name": "1. Assign Plan — Valid → 201",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{SUPER_ADMIN_TOKEN}}" },
              { "key": "Content-Type",  "value": "application/json" }
            ],
            "url": "{{BASE_URL}}/api/v1/super-admin/subscriptions",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"{{VALID_TENANT_ID}}\",\n  \"planId\": \"{{VALID_PLAN_ID}}\",\n  \"billingCycle\": \"monthly\",\n  \"amountPaid\": \"999.00\"\n}"
            }
          },
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "pm.test('Status is 201', () => pm.expect(pm.response.code).to.equal(201));",
                "pm.test('success is true', () => pm.expect(pm.response.json().success).to.be.true);",
                "pm.test('Has data.id', () => pm.expect(pm.response.json().data).to.have.property('id'));",
                "pm.test('tenantId matches', () => pm.expect(pm.response.json().data.tenantId).to.equal(pm.collectionVariables.get('VALID_TENANT_ID')));",
                "const id = pm.response.json().data?.id;",
                "if (id) pm.collectionVariables.set('SUBSCRIPTION_ID', id);"
              ]
            }
          }]
        },

