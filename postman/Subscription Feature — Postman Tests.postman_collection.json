    {
      "name": "── Super Admin — Create & Assign ────────",
      "item": [
        {
          "name": "SA.1 — Create monthly subscription for school → 201",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "const d = pm.response.json().data;",
                  "pm.collectionVariables.set('SUB_ID', d.id);",
                  "pm.test('Has id', () => pm.expect(d.id).to.be.a('string'));",
                  "pm.test('Status is trialing', () => pm.expect(d.status).to.equal('trialing'));",
                  "pm.test('billingCycle is monthly', () => pm.expect(d.billingCycle).to.equal('monthly'));",
                  "const diff = (new Date(d.endDate) - new Date(d.startDate)) / 86400000;",
                  "pm.test('endDate is ~30 days out', () => pm.expect(diff).to.be.closeTo(30, 1));",
                  "pm.test('amountPaid is above 0', () => pm.expect(d.amountPaid).to.be.above(0));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{SUPER_ADMIN_TOKEN}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"tenantId\": \"{{TENANT_ID}}\",\n  \"planId\": \"{{ACTIVE_PLAN_ID}}\",\n  \"billingCycle\": \"monthly\"\n}"
            },
            "url": {
              "raw": "{{BASE_URL}}/super-admin/subscriptions",
              "host": [
                "{{BASE_URL}}"
              ],
              "path": [
                "super-admin",
                "subscriptions"
              ]
