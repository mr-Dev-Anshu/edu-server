  "variable": [
    { "key": "BASE_URL",            "value": "http://localhost:3000" },
    { "key": "SUPER_ADMIN_TOKEN",   "value": "YOUR_SUPER_ADMIN_JWT_HERE" },
    { "key": "SCHOOL_OWNER_TOKEN",  "value": "YOUR_SCHOOL_OWNER_JWT_HERE" },
    { "key": "WRONG_ROLE_TOKEN",    "value": "YOUR_WRONG_ROLE_JWT_HERE" },
    { "key": "VALID_TENANT_ID",     "value": "REPLACE_WITH_REAL_TENANT_UUID" },
    { "key": "VALID_PLAN_ID",       "value": "REPLACE_WITH_REAL_PLAN_UUID" },
