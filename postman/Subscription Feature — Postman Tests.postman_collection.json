    {
      "name": "1. Assign Plan — Valid (Super Admin) → 201",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Status is 201 or 200', () => pm.expect(pm.response.code).to.be.oneOf([201, 200]));",
              "pm.test('success is true', () => pm.expect(pm.response.json().success).to.be.true);",
              "const id = pm.response.json().data?.id;",
              "if (id) pm.collectionVariables.set('SUBSCRIPTION_ID', id);"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{SUPER_ADMIN_TOKEN}}"
          },
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"tenantId\": \"{{VALID_TENANT_ID}}\",\n  \"planId\": \"{{VALID_PLAN_ID}}\",\n  \"billingCycle\": \"monthly\",\n  \"amountPaid\": \"999.00\"\n}"
        },
        "url": {
          "raw": "{{BASE_URL}}/api/v1/super-admin/subscriptions",
          "host": [
            "{{BASE_URL}}"
          ],
          "path": [
            "api",
