          "raw": "{\n  \"name\": \"create:assign_permissions_students\",\n  \"action\": \"create\",\n  \"resource\": \"assign_permissions_students\",\n  \"module\": \"rbac\",\n  \"description\": \"Primary permission used while testing assign-permissions route\"\n}"
