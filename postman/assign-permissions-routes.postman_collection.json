    {
      "name": "Create Role - Assign Permissions Target",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code >= 200 && pm.response.code < 300) {",
              "  const json = pm.response.json();",
              "  if (json.data && json.data.id) {",
              "    pm.environment.set('assignPermissionRoleId', json.data.id);",
              "  }",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "x-tenant-id",
            "value": "{{tenantId}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Assign Permissions Test Role\",\n  \"slug\": \"assign-permissions-test-role\",\n  \"description\": \"Role created specifically for assign-permissions route testing\",\n  \"hierarchyLevel\": 5,\n  \"permissionIds\": [\n    \"{{assignPermissionPrimaryId}}\"\n  ],\n  \"customFields\": {\n    \"source\": \"postman\"\n  },\n  \"metadata\": {\n    \"route\": \"assign-permissions\"\n  }\n}"
        },
        "url": {
          "raw": "{{roleBaseUrl}}",
          "host": [
            "{{roleBaseUrl}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Assign Permissions To Role",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function () {",
              "  pm.response.to.have.status(200);",
              "});",
              "",
              "const json = pm.response.json();",
              "pm.test('Route returns success true', function () {",
              "  pm.expect(json.success).to.eql(true);",
              "});",
              "",
              "pm.test('Route returns updated permissions', function () {",
              "  pm.expect(json.data.permissions).to.be.an('array');",
              "  pm.expect(json.data.permissions.length).to.eql(2);",
              "});"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "x-tenant-id",
            "value": "{{tenantId}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"permissionIds\": [\n    \"{{assignPermissionPrimaryId}}\",\n    \"{{assignPermissionSecondaryId}}\"\n  ]\n}"
        },
        "url": {
          "raw": "{{roleBaseUrl}}/{{assignPermissionRoleId}}/assign-permissions",
          "host": [
            "{{roleBaseUrl}}"
          ],
          "path": [
            "{{assignPermissionRoleId}}",
            "assign-permissions"
          ]
        }
