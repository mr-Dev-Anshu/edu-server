  "item": [
    {
      "name": "Create Permission - Assign Permissions Primary",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code >= 200 && pm.response.code < 300) {",
              "  const json = pm.response.json();",
              "  if (json.data && json.data.id) {",
              "    pm.environment.set('assignPermissionPrimaryId', json.data.id);",
              "  }",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
