    {
      "name": "Attendance - Bulk Mark",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"records\": [\n    {\n      \"studentId\": \"{{studentId1}}\",\n      \"sectionId\": \"{{sectionId}}\",\n      \"academicYearId\": \"{{academicYearId}}\",\n      \"date\": \"{{date}}\",\n      \"status\": \"present\"\n    },\n    {\n      \"studentId\": \"{{studentId2}}\",\n      \"sectionId\": \"{{sectionId}}\",\n      \"academicYearId\": \"{{academicYearId}}\",\n      \"date\": \"{{date}}\",\n      \"status\": \"absent\",\n      \"remarks\": \"Sick leave\"\n    },\n    {\n      \"studentId\": \"{{studentId3}}\",\n      \"sectionId\": \"{{sectionId}}\",\n      \"academicYearId\": \"{{academicYearId}}\",\n      \"date\": \"{{date}}\",\n      \"status\": \"late\",\n      \"inTime\": \"09:20:00\"\n    }\n  ]\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/attendance/bulk-mark",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "attendance", "bulk-mark"]
        },
        "description": "Mark attendance for multiple students at once (transactional)"
      },
      "response": []
