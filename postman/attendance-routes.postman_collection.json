  "item": [
    {
      "name": "Attendance - Create",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"studentId\": \"{{studentId}}\",\n  \"sectionId\": \"{{sectionId}}\",\n  \"academicYearId\": \"{{academicYearId}}\",\n  \"date\": \"{{date}}\",\n  \"status\": \"present\",\n  \"inTime\": \"09:00:00\",\n  \"outTime\": \"15:30:00\",\n  \"remarks\": \"Student was on time\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/attendance",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "attendance"]
        },
        "description": "Mark attendance for a student"
      },
      "response": []
    },
