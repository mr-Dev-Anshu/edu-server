        {
          "name": "5. Login - Org Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const json = pm.response.json();",
                  "  if (json.data && json.data.token) {",
                  "    pm.environment.set('orgAdminToken', json.data.token);",
                  "    pm.environment.set('loggedInUserId', json.data.id);",
                  "    pm.environment.set('loggedInUserType', json.data.userType);",
                  "    console.log('✓ Login successful for:', json.data.email);",
                  "    console.log('✓ Token stored:', json.data.token.substring(0, 20) + '...');",
                  "  }",
                  "} else {",
                  "  console.log('✗ Login failed:', pm.response.text());",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"orgadmin@testschool.com\",\n  \"password\": \"OrgAdmin@123\"\n}"
            },
            "url": {
              "raw": "{{userBaseUrl}}/login",
              "host": [
                "{{userBaseUrl}}",
                "login"
              ]
            }
          },
          "response": []
