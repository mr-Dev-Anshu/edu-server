      "name": "Authentication",
      "item": [
        {
          "name": "1. Create Test Org Admin User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const json = pm.response.json();",
                  "  if (json.data && json.data.id) {",
                  "    pm.environment.set('orgAdminUserId', json.data.id);",
                  "    pm.environment.set('orgAdminEmail', json.data.email);",
                  "  }",
                  "} else {",
                  "  console.log('Response Status:', pm.response.code);",
                  "  console.log('Response:', pm.response.text());",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"orgadmin@testschool.com\",\n  \"password\": \"OrgAdmin@123\",\n  \"firstName\": \"Organization\",\n  \"lastName\": \"Admin\",\n  \"userType\": \"org_admin\",\n  \"phone\": \"+91-9876543210\",\n  \"status\": \"active\",\n  \"emailVerified\": true,\n  \"preferences\": {\n    \"language\": \"en\",\n    \"theme\": \"system\"\n  }\n}"
            },
            "url": {
              "raw": "{{userBaseUrl}}",
              "host": [
                "{{userBaseUrl}}"
              ]
            }
          },
          "response": []
        },
