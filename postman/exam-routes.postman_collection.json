                  "    }",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-tenant-id", "value": "{{tenantId}}" },
              { "key": "Authorization", "value": "Bearer {{orgAdminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Percentage Scale With Rules\",\n  \"scaleType\": \"percentage\",\n  \"isDefault\": false,\n  \"gradeScaleRules\": [\n    {\n      \"gradeLabel\": \"A+\",\n      \"minPercentage\": 90,\n      \"maxPercentage\": 100,\n      \"gradePoint\": 4\n    },\n    {\n      \"gradeLabel\": \"A\",\n      \"minPercentage\": 80,\n      \"maxPercentage\": 89.99,\n      \"gradePoint\": 3.5\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/grade-scales",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "grade-scales"]
            }
          },
          "response": []
