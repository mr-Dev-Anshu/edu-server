  "item": [
    {
      "name": "Grade Scales",
      "item": [
        {
          "name": "Create Grade Scale Without Rules",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const json = pm.response.json();",
                  "  if (json.data && json.data.id) {",
                  "    pm.environment.set('gradeScaleId', json.data.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "x-tenant-id", "value": "{{tenantId}}" },
              { "key": "Authorization", "value": "Bearer {{orgAdminToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Percentage Scale\",\n  \"scaleType\": \"percentage\",\n  \"isDefault\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/grade-scales",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "grade-scales"]
            }
          },
          "response": []
        },
        {
          "name": "Create Grade Scale With Rules",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const json = pm.response.json();",
                  "  if (json.data && json.data.id) {",
                  "    pm.environment.set('gradeScaleWithRulesId', json.data.id);",
                  "    if (json.data.gradeScaleRules && json.data.gradeScaleRules.length) {",
