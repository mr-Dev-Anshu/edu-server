  "item": [
    {
      "name": "FeeHead",
      "item": [
        {
          "name": "Create FeeHead",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const json = pm.response.json();",
                  "  if (json.data && json.data.id) {",
                  "    pm.environment.set('feeHeadId', json.data.id);",
                  "  }",
                  "  console.log('FeeHead created successfully:', json.data);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{authToken}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Tuition Fee\",\n  \"description\": \"Basic tuition fee for all classes\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/fee-heads",
              "host": ["{{baseUrl}}"],
              "path": ["api", "v1", "fee-heads"]
            }
          },
          "response": []
