            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "x-tenant-id",
            "value": "{{tenant_id}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"teacher@school.com\",\n  \"password\": \"SecurePassword123\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/users/auth/login",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "users", "auth", "login"]
        },
        "description": "Successfully login with valid credentials"
      },
      "response": []
