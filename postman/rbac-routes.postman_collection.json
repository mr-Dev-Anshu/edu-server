  "item": [
    {
      "name": "Create Permission - Create Students",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code >= 200 && pm.response.code < 300) {",
              "  const json = pm.response.json();",
              "  if (json.data && json.data.id) {",
              "    pm.environment.set('createStudentsPermissionId', json.data.id);",
              "  }",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"create:abc_public_school_students\",\n  \"action\": \"create\",\n  \"resource\": \"abc_public_school_students\",\n  \"module\": \"academics\",\n  \"description\": \"Allows ABC Public School staff to create student records\"\n}"
        },
        "url": {
          "raw": "{{permissionBaseUrl}}",
          "host": [
            "{{permissionBaseUrl}}"
          ]
        }
      },
      "response": []
    },
