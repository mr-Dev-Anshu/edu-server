{
  "info": {
    "_postman_id": "section-routes-collection",
    "name": "Edu Server Section CRUD Routes",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for testing section management CRUD operations."
  },
  "item": [
    {
      "name": "Create Section",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code >= 200 && pm.response.code < 300) {",
              "  const json = pm.response.json();",
              "  if (json.data && json.data.id) {",
              "    pm.environment.set('sectionId', json.data.id);",
              "  }",
              "  console.log('Section created successfully:', json.data);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "x-tenant-id", "value": "{{tenantId}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"A\",\n  \"classId\": \"{{classId}}\",\n  \"academicYearId\": \"{{academicYearId}}\",\n  \"capacity\": 40\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/sections",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "sections"]
        }
      }
    },
    {
      "name": "Get All Sections",
      "request": {
        "method": "GET",
        "header": [
          { "key": "x-tenant-id", "value": "{{tenantId}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/sections?page=1&limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "sections"],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "10" }
          ]
        }
      }
    },
    {
      "name": "Get Section by ID",
      "request": {
        "method": "GET",
        "header": [
          { "key": "x-tenant-id", "value": "{{tenantId}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/sections/{{sectionId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "sections", "{{sectionId}}"]
        }
      }
    },
    {
      "name": "Update Section",
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "x-tenant-id", "value": "{{tenantId}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"A-Updated\",\n  \"capacity\": 45\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/sections/{{sectionId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "sections", "{{sectionId}}"]
        }
      }
    },
    {
      "name": "Delete Section",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "x-tenant-id", "value": "{{tenantId}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/sections/{{sectionId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "sections", "{{sectionId}}"]
        }
      }
    }
  ]
}