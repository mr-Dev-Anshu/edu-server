{
  "info": {
    "_postman_id": "staff-routes-collection",
    "name": "Edu Server Staff CRUD Routes",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for testing staff management CRUD operations."
  },
  "item": [
    {
      "name": "Create Staff",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code >= 200 && pm.response.code < 300) {",
              "  const json = pm.response.json();",
              "  if (json.data && json.data.id) {",
              "    pm.environment.set('staffId', json.data.id);",
              "  }",
              "  console.log('Staff created successfully:', json.data);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "x-tenant-id",
            "value": "{{tenantId}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"employeeCode\": \"EMP-001\",\n  \"staffType\": \"teaching\",\n  \"designation\": \"Mathematics Teacher\",\n  \"department\": \"Science\",\n  \"joiningDate\": \"2024-01-15\",\n  \"employmentStatus\": \"confirmed\",\n  \"panNumber\": \"ABCD1234567\",\n  \"bankAccountNumber\": \"1234567890\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/staff",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "staff"]
        }
      },
      "response": []
    },
    {
      "name": "Get All Staff",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "x-tenant-id",
            "value": "{{tenantId}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/staff?page=1&limit=10&staffType=teaching",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "staff"],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            },
            {
              "key": "staffType",
              "value": "teaching"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Staff by ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "x-tenant-id",
            "value": "{{tenantId}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/staff/{{staffId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "staff", "{{staffId}}"]
        }
      },
      "response": []
    },
    {
      "name": "Update Staff",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "x-tenant-id",
            "value": "{{tenantId}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"designation\": \"Senior Mathematics Teacher\",\n  \"employmentStatus\": \"confirmed\",\n  \"department\": \"Core Science\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/staff/{{staffId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "staff", "{{staffId}}"]
        }
      },
      "response": []
    },
    {
      "name": "Search Staff",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "x-tenant-id",
            "value": "{{tenantId}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/staff/search?q=EMP",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "staff", "search"],
          "query": [
            {
              "key": "q",
              "value": "EMP"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Delete Staff",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "x-tenant-id",
            "value": "{{tenantId}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/staff/{{staffId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "staff", "{{staffId}}"]
        }
      },
      "response": []
    }
  ]
}
