{
  "info": {
    "_postman_id": "student-routes-collection",
    "name": "Edu Server Student CRUD Routes",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for testing student CRUD operations."
  },
  "item": [
    {
      "name": "Create Student",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code >= 200 && pm.response.code < 300) {",
              "  const json = pm.response.json();",
              "  if (json.data && json.data.id) {",
              "    pm.environment.set('studentId', json.data.id);",
              "  }",
              "  console.log('Student created successfully:', json.data);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "x-tenant-id",
            "value": "{{tenantId}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"sana.student2026@s.com\",\n  \"password\": \"SecureStudent@128\",\n  \"firstName\": \"Sana\",\n  \"middleName\": \"Fatima\",\n  \"lastName\": \"Sheikh\",\n  \"admissionNumber\": \"VSS-ADM-2026-014\",\n  \"rollNumber\": \"20\",\n  \"dateOfBirth\": \"2012-12-11\",\n  \"gender\": \"female\",\n  \"bloodGroup\": \"A-\",\n  \"nationality\": \"Indian\",\n  \"religion\": \"Islam\",\n  \"category\": \"general\",\n  \"aadharNumber\": \"5555-6666-7777\",\n  \"enrollmentDate\": \"2026-04-19\",\n  \"previousSchool\": \"Oxford Kids School\",\n  \"previousClass\": \"5th Standard\",\n  \"isStaffWard\": false,\n  \"status\": \"active\",\n  \"transportRequired\": true,\n  \"hostelRequired\": false,\n  \"medicalConditions\": \"None\",\n  \"emergencyContactName\": \"Yusuf Sheikh\",\n  \"emergencyContactPhone\": \"9876500015\",\n  \"address\": \"Apartment 9B, Lalghati\",\n  \"city\": \"Bhopal\",\n  \"pincode\": \"462030\",\n  \"sectionId\": \"{{sectionId}}\",\n  \"academicYearId\": \"{{academicYearId}}\",\n  \"enrollmentStatus\": \"regular\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/students",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
