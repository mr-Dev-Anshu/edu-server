{
  "info": {
    "_postman_id": "student-routes-collection",
    "name": "Edu Server Student CRUD Routes",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for testing student CRUD operations."
  },
  "item": [
    {
      "name": "Create Student",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code >= 200 && pm.response.code < 300) {",
              "  const json = pm.response.json();",
              "  if (json.data && json.data.id) {",
              "    pm.environment.set('studentId', json.data.id);",
              "  }",
              "  console.log('Student created successfully:', json.data);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "x-tenant-id",
            "value": "{{tenantId}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"userId\": \"{{userId}}\",\n  \"admissionNumber\": \"ADM-001\",\n  \"firstName\": \"Amit\",\n  \"lastName\": \"Sharma\",\n  \"dateOfBirth\": \"2010-07-14\",\n  \"gender\": \"male\",\n  \"enrollmentDate\": \"2024-06-04\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/students",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "students"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get All Students",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "x-tenant-id",
            "value": "{{tenantId}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/students?page=1&limit=10&status=active",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "students"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            },
            {
              "key": "status",
              "value": "active"
            }
          ]
        }
      },
      "response": []
    },
    {
      "name": "Get Student by ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "x-tenant-id",
            "value": "{{tenantId}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/students/{{studentId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "students",
            "{{studentId}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Update Student",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "x-tenant-id",
            "value": "{{tenantId}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"middleName\": \"Kumar\",\n  \"city\": \"Bangalore\"\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/students/{{studentId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "students",
            "{{studentId}}"
          ]
        }
      },
      "response": []
    },
    {
      "name": "Delete Student",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "x-tenant-id",
            "value": "{{tenantId}}"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/students/{{studentId}}",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "api",
            "v1",
            "students",
            "{{studentId}}"
          ]
        }
      },
      "response": []
    }
  ]
}
