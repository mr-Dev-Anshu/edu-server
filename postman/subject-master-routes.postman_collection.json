{
  "info": {
    "_postman_id": "subject-master-collection",
    "name": "Subject Master APIs",
    "description": "APIs for managing Subject Masters in the Educational Platform",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Create Subject",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "if (!pm.environment.get('base_url')) {",
              "    pm.environment.set('base_url', 'http://localhost:5000');",
              "}",
              "if (!pm.environment.get('tenant_id')) {",
              "    pm.environment.set('tenant_id', '');",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{auth_token}}"
          },
          {
            "key": "x-tenant-id",
            "value": "{{tenant_id}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Mathematics\",\n  \"type\": \"theory\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/subjects/subject-master",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "subjects",
            "subject-master"
          ]
        },
        "description": "Create a new Subject Master"
      },
      "response": []
    },
    {
      "name": "Get All Subjects",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{auth_token}}"
          },
          {
            "key": "x-tenant-id",
            "value": "{{tenant_id}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/subjects/subject-master?page=1&limit=10&type=theory",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "subjects",
            "subject-master"
          ],
          "query": [
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            },
            {
              "key": "type",
              "value": "theory",
              "disabled": true
            }
          ]
        },
        "description": "Get all Subject Masters with pagination and filters"
      },
      "response": []
    },
    {
      "name": "Search Subjects",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{auth_token}}"
          },
          {
            "key": "x-tenant-id",
            "value": "{{tenant_id}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/subjects/subject-master/search?search=Math&page=1&limit=10",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "subjects",
            "subject-master",
            "search"
          ],
          "query": [
            {
              "key": "search",
              "value": "Math"
            },
            {
              "key": "page",
              "value": "1"
            },
            {
              "key": "limit",
              "value": "10"
            }
          ]
        },
        "description": "Search subjects by name"
      },
      "response": []
    },
    {
      "name": "Get Subject by ID",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{auth_token}}"
          },
          {
            "key": "x-tenant-id",
            "value": "{{tenant_id}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/subjects/subject-master/{{subject_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "subjects",
            "subject-master",
            "{{subject_id}}"
          ]
        },
        "description": "Get a specific Subject by ID"
      },
      "response": []
    },
    {
      "name": "Get Subject with Classes",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{auth_token}}"
          },
          {
            "key": "x-tenant-id",
            "value": "{{tenant_id}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/subjects/subject-master/{{subject_id}}/classes",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "subjects",
            "subject-master",
            "{{subject_id}}",
            "classes"
          ]
        },
        "description": "Get a Subject with all mapped Classes"
      },
      "response": []
    },
    {
      "name": "Update Subject",
      "request": {
        "method": "PATCH",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{auth_token}}"
          },
          {
            "key": "x-tenant-id",
            "value": "{{tenant_id}}"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Advanced Mathematics\",\n  \"type\": \"both\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/subjects/subject-master/{{subject_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "subjects",
            "subject-master",
            "{{subject_id}}"
          ]
        },
        "description": "Update an existing Subject Master"
      },
      "response": []
    },
    {
      "name": "Delete Subject",
      "request": {
        "method": "DELETE",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{auth_token}}"
          },
          {
            "key": "x-tenant-id",
            "value": "{{tenant_id}}"
          }
        ],
        "url": {
          "raw": "{{base_url}}/api/v1/subjects/subject-master/{{subject_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "subjects",
            "subject-master",
            "{{subject_id}}"
          ]
        },
        "description": "Delete a Subject Master"
      },
      "response": []
    }
  ]
}
