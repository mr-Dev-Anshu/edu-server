{
  "info": {
    "_postman_id": "subject-routes-collection",
    "name": "Edu Server Subject CRUD Routes",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Postman collection for testing Subject management CRUD + search routes."
  },
  "item": [
    {
      "name": "Create Subject",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code >= 200 && pm.response.code < 300) {",
              "  const json = pm.response.json();",
              "  if (json.data && json.data.id) pm.environment.set('subjectId', json.data.id);",
              "  if (json.data && json.data.code) pm.environment.set('subjectCode', json.data.code);",
              "  console.log('Subject created:', json.data);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{orgAdminToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"classId\": \"{{classId}}\",\n  \"name\": \"Mathematics\",\n  \"code\": \"MATH101\",\n  \"subjectType\": \"theory\",\n  \"isElective\": false,\n  \"weeklyPeriods\": 5\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/subjects",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "subjects"]
        }
      }
    },
    {
      "name": "Get All Subjects",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{orgAdminToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/subjects?page=1&limit=10&classId={{classId}}&subjectType=theory&isElective=false",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "subjects"],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "10" },
            { "key": "classId", "value": "{{classId}}" },
            { "key": "subjectType", "value": "theory" },
            { "key": "isElective", "value": "false" }
          ]
        }
      }
    },
    {
      "name": "Search Subjects",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{orgAdminToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/subjects/search?q=math&page=1&limit=10&classId={{classId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "subjects", "search"],
          "query": [
            { "key": "q", "value": "math" },
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "10" },
            { "key": "classId", "value": "{{classId}}" }
          ]
        }
      }
    },
    {
      "name": "Get Subjects By Class",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{orgAdminToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/subjects/by-class/{{classId}}?page=1&limit=10",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "subjects", "by-class", "{{classId}}"],
          "query": [
            { "key": "page", "value": "1" },
            { "key": "limit", "value": "10" }
          ]
        }
      }
    },
    {
      "name": "Get Subject By ID",
      "request": {
        "method": "GET",
        "header": [
          { "key": "Authorization", "value": "Bearer {{orgAdminToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/subjects/{{subjectId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "subjects", "{{subjectId}}"]
        }
      }
    },
    {
      "name": "Update Subject",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code >= 200 && pm.response.code < 300) {",
              "  const json = pm.response.json();",
              "  if (json.data && json.data.code) pm.environment.set('subjectCode', json.data.code);",
              "  console.log('Subject updated:', json.data);",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "PATCH",
        "header": [
          { "key": "Authorization", "value": "Bearer {{orgAdminToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Advanced Mathematics\",\n  \"code\": \"MATH-ADV\",\n  \"subjectType\": \"theory\",\n  \"isElective\": false,\n  \"weeklyPeriods\": 6\n}"
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/subjects/{{subjectId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "subjects", "{{subjectId}}"]
        }
      }
    },
    {
      "name": "Delete Subject",
      "request": {
        "method": "DELETE",
        "header": [
          { "key": "Authorization", "value": "Bearer {{orgAdminToken}}" }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/subjects/{{subjectId}}",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "subjects", "{{subjectId}}"]
        }
      }
    }
  ]
}
