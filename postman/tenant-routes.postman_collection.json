    {
      "name": "Create Tenant",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "if (pm.response.code >= 200 && pm.response.code < 300) {",
              "  const json = pm.response.json();",
              "  if (json.data && json.data.id) {",
              "    pm.environment.set('tenantId', json.data.id);",
              "  }",
              "  if (json.data && json.data.portalUrl) {",
              "    pm.environment.set('tenantPortalUrl', json.data.portalUrl);",
              "  }",
              "}"
            ]
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"name\": \"Sanu Public School\",\n  \"organizationType\": \"school\",\n  \"officialEmail\": \"admin.sps@example.com\",\n  \"subdomain\": \"sanu-public-school\",\n  \"plan\": \"{{planSlug}}\",\n  \"billingCycle\": \"monthly\",\n  \"trialDays\": 14,\n  \"registrationNumber\": \"SPS-2026-001\",\n  \"settings\": {\n    \"academicStructure\": \"k12\",\n    \"hasHostel\": true,\n    \"hasTransport\": true,\n    \"gradingSystem\": \"percentage\",\n    \"timezone\": \"Asia/Kolkata\",\n    \"currency\": \"INR\"\n  },\n  \"address\": {\n    \"line1\": \"12 Knowledge Avenue\",\n    \"line2\": \"Near City Library\",\n    \"city\": \"Kolkata\",\n    \"state\": \"West Bengal\",\n    \"country\": \"India\",\n    \"postalCode\": \"700001\"\n  },\n  \"contactInfo\": {\n    \"primaryPhone\": \"+91-9876543210\",\n    \"alternatePhone\": \"+91-9000000001\",\n    \"contactPerson\": \"Sanu Admin\",\n    \"website\": \"https://sanu-public-school.example.com\"\n  },\n  \"themeConfig\": {\n    \"primaryColor\": \"#2563EB\",\n    \"secondaryColor\": \"#1D4ED8\",\n    \"accentColor\": \"#0F172A\",\n    \"fontFamily\": \"Inter\"\n  },\n  \"brandingAssets\": {\n    \"logoUrl\": \"https://dummyimage.com/256x256/2563eb/ffffff.png&text=SPS\",\n    \"faviconUrl\": \"https://dummyimage.com/64x64/1d4ed8/ffffff.png&text=S\",\n    \"coverImageUrl\": \"https://dummyimage.com/1200x300/0f172a/ffffff.png&text=Sanu+Public+School\"\n  },\n  \"customFields\": {\n    \"board\": \"CBSE\"\n  },\n  \"metadata\": {\n    \"createdFrom\": \"postman\"\n  }\n}"
