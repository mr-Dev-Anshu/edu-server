    {
      "name": "Users",
      "item": [
        {
          "name": "Create Org Admin User",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (pm.response.code >= 200 && pm.response.code < 300) {",
                  "  const json = pm.response.json();",
                  "  if (json.data && json.data.id) {",
                  "    pm.environment.set('userId', json.data.id);",
                  "  }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-tenant-id",
                "value": "{{tenantId}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"org.admin.{{$timestamp}}@example.com\",\n  \"password\": \"Password@123\",\n  \"firstName\": \"Org\",\n  \"lastName\": \"Admin\",\n  \"userType\": \"org_admin\",\n  \"phone\": \"+91-9000000001\",\n  \"status\": \"active\",\n  \"emailVerified\": false,\n  \"preferences\": {\n    \"language\": \"en\",\n    \"theme\": \"system\"\n  },\n  \"metadata\": {\n    \"createdFrom\": \"postman-user-collection\"\n  }\n}"
            },
            "url": {
              "raw": "{{userBaseUrl}}",
              "host": [
                "{{userBaseUrl}}"
              ]
            }
          },
          "response": []
        },
